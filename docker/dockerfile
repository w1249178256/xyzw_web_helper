# 构建流程:
#   Step 1 (首次/依赖变更时): sh docker/install.sh deps
#   Step 2 (每次发布):        sh docker/install.sh build

# ---- Stage 1: Build ----
# 使用预装了依赖的本地镜像，node_modules 已就绪，无需联网
FROM xyzw-deps:latest AS builder

WORKDIR /app
COPY . .
RUN pnpm run build

# ---- Stage 2: Serve ----
# 同样基于 xyzw-deps（node:20-alpine），安装 nginx，无需再拉镜像
FROM xyzw-deps:latest AS server

ARG HTTP_PROXY=""
ARG HTTPS_PROXY=""

RUN http_proxy=${HTTP_PROXY} https_proxy=${HTTPS_PROXY} \
    apk add --no-cache nginx && \
    # nginx 默认不创建 /run/nginx 目录
    mkdir -p /run/nginx

COPY --from=builder /app/dist /app/web
COPY docker/nginx.conf /etc/nginx/nginx.conf

# 清理 node 相关内容，减小镜像体积
RUN rm -rf /app/node_modules /usr/local/lib/node_modules \
           /usr/local/bin/node /usr/local/bin/npm /usr/local/bin/pnpm \
           /usr/local/bin/corepack

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
